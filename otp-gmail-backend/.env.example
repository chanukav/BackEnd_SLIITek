# Copy this file to .env and fill in your values.
# Use a Gmail App Password (Google Account → Security → 2-Step Verification → App passwords).
# Do NOT use your normal Gmail sign-in password.
#
# The main BackEngine also loads this file automatically so EMAIL/PASS work there too.
# Or set EMAIL_USER / EMAIL_PASS in the repo root .env (same Gmail + app password).

EMAIL=yourgmail@gmail.com
PASS=your_16_char_app_password_without_spaces
PORT=5000
