# Copy to .env and fill in. No angle brackets or "xxxx" demo strings.

# Sign-up email verification (Gmail: use an App Password, not your normal password)
EMAIL_USER=
EMAIL_PASS=
# Optional: different From: address if your provider allows it (defaults to EMAIL_USER)
# EMAIL_FROM=

# Use explicit SMTP instead of Gmail defaults (e.g. Outlook, SendGrid):
# EMAIL_SMTP_HOST=smtp.office365.com
# EMAIL_SMTP_PORT=587

# Copy verification emails to your inbox (the address in EMAIL_USER or a list):
# EMAIL_VERIFICATION_BCC_SENDER=true
# EMAIL_VERIFICATION_BCC=you@example.com,backup@example.com

# https://console.twilio.com/ — Account SID (AC…) and Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Verify → Services → your service — Service SID (VA…)
TWILIO_VERIFY_SERVICE_SID=

# If WhatsApp fails, Twilio Verify retries with SMS by default. Set to false to allow WhatsApp only.
# TWILIO_VERIFY_FALLBACK_SMS=false

# Forgot-password OTP uses the same email settings as sign-up verification.
